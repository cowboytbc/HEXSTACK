{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Windows Deliverables",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\build-and-refresh-windows.ps1"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Refresh Deliverables Only",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\refresh-deliverables.ps1"
      ],
      "problemMatcher": []
    },
    {
      "label": "Install VST3 To System Folder",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\install-vst3-to-system-folder.ps1"
      ],
      "problemMatcher": []
    },
    {
      "label": "Make Windows Release Bundle",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\make-release-bundle.ps1"
      ],
      "problemMatcher": []
    }
  ]
}
